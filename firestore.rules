rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /players/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /games/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /activeGame/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /certifications/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /spectatorStats/{doc} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
  }
}
